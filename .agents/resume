#!/usr/bin/env bash

set -euo pipefail

readonly PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "$PROJECT_ROOT"

# The orb uses SQLite and file-backed Laravel stores, so there are no external
# services to reconnect. Repair only the writable runtime paths that may be
# removed by test cleanup or an interrupted command.
mkdir -p \
    storage/framework/cache/data \
    storage/framework/sessions \
    storage/framework/testing \
    storage/framework/views \
    storage/logs

echo 'Orb runtime paths are ready.'
