#!/usr/bin/env bash

set -euo pipefail

readonly PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly BUN_VERSION='1.3.10'

export DEBIAN_FRONTEND=noninteractive
export PATH="$HOME/.bun/bin:$HOME/.local/bin:/usr/bin:$PATH"

cd "$PROJECT_ROOT"

echo '==> Installing orb system dependencies'
sudo apt-get update -qq
sudo apt-get install -y -qq ca-certificates curl qpdf unzip

if ! command -v node >/dev/null 2>&1 || [[ "$(node --version)" != v22.* ]]; then
    echo '==> Installing Node.js 22 for Vite'
    curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash -
    sudo apt-get install -y -qq nodejs
fi

echo '==> Installing FrankenPHP, PHP 8.5, and Composer'
bash scripts/setup-steps/15-runtime.sh local

echo "==> Installing Bun ${BUN_VERSION}"
if ! command -v bun >/dev/null 2>&1 || [[ "$(bun --version)" != "$BUN_VERSION" ]]; then
    curl -fsSL https://bun.sh/install | bash -s "bun-v${BUN_VERSION}"
    export PATH="$HOME/.bun/bin:$PATH"
fi

echo '==> Preparing the local orb environment'
if [[ ! -f .env ]]; then
    cp -- .env.example .env
fi

set_env() {
    local key=$1
    local value=$2

    if grep -q "^${key}=" .env; then
        sed -i "s|^${key}=.*|${key}=${value}|" .env
    else
        printf '%s=%s\n' "$key" "$value" >> .env
    fi
}

set_env APP_ENV local
if ! grep -q '^APP_KEY=' .env; then
    printf 'APP_KEY=\n' >> .env
fi
set_env APP_SCHEME http
set_env APP_URL http://127.0.0.1:8000
set_env DB_CONNECTION sqlite
set_env DB_DATABASE "$PROJECT_ROOT/database/database.sqlite"
set_env CACHE_STORE file
set_env QUEUE_CONNECTION sync
set_env SESSION_DRIVER file
set_env AI_BROWSER_HEADLESS true

mkdir -p \
    database \
    storage/app/sqlite-ext \
    storage/framework/cache/data \
    storage/framework/sessions \
    storage/framework/testing \
    storage/framework/views \
    storage/logs
touch database/database.sqlite

echo '==> Installing locked PHP and JavaScript dependencies'
composer install --no-interaction --prefer-dist --optimize-autoloader
bun install --frozen-lockfile

echo '==> Installing sqlite-vec and Chromium'
bash scripts/setup-steps/22-sqlite-vec.sh local
bunx playwright install --with-deps chromium

if ! grep -q '^APP_KEY=base64:' .env; then
    php artisan key:generate --force --no-interaction
fi

echo '==> Preparing the application database and assets'
admin_bootstrap_file=$(mktemp)
trap 'rm -f "$admin_bootstrap_file"' EXIT
printf '%s\n' 'Orb Admin' 'admin@example.test' 'password' > "$admin_bootstrap_file"
LICENSEE_COMPANY_NAME='Belimbing Orb' \
LICENSEE_COMPANY_CODE='BLB' \
BLB_BOOTSTRAP_ADMIN_FILE="$admin_bootstrap_file" \
    php artisan migrate --force --no-interaction
rm -f "$admin_bootstrap_file"
trap - EXIT
bun run build

echo '==> Orb setup complete'
php --version | head -n 1
composer --version
bun --version
qpdf --version | head -n 1
