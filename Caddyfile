# FrankenPHP Caddyfile — read by FrankenPHP's embedded Caddy (via Octane).
# {$VAR:default} placeholders are resolved by Caddy from environment variables at startup.
# Vite remains reverse_proxy because it is a separate Node process.
#
# Octane passes --caddyfile=Caddyfile so this file is used instead of the
# default stub. The frankenphp worker block and admin endpoint mirror what
# the stub provides; the site blocks add TLS and Vite proxying.
{
	servers {
		protocols h1 h2 h3
	}

	frankenphp {
		# Item photo upload allows 12 files x 10 MB (Livewire posts them in one
		# request). PHP's defaults (2M/8M) silently rejected phone photos before
		# application validation could explain why; keep PHP's ceiling above the
		# app's so the validator message is the one users see.
		php_ini upload_max_filesize 12M
		php_ini post_max_size 130M

		worker {
			file {$APP_PUBLIC_PATH}/frankenphp-worker.php
			{$CADDY_SERVER_WORKER_DIRECTIVE}
			{$CADDY_SERVER_WATCH_DIRECTIVES}
		}
	}

	admin {$CADDY_SERVER_ADMIN_HOST:localhost}:{$CADDY_SERVER_ADMIN_PORT:2019}
}

# Defense-in-depth security headers for responses FrankenPHP serves directly
# (favicon, built assets) that never pass through Laravel's SecurityHeaders
# middleware. The `?` prefix sets each header only if absent, so PHP responses
# keep the app's own (richer, config-driven) Content-Security-Policy. Keep this
# CSP in sync with config/security.php.
(security_headers) {
	header {
		?X-Content-Type-Options "nosniff"
		?X-Frame-Options "DENY"
		?Referrer-Policy "strict-origin-when-cross-origin"
		?Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		?Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.bunny.net; font-src 'self' https://fonts.bunny.net data:; img-src 'self' data: blob:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
	}
}

{$CADDY_SCHEME:https}://{$APP_DOMAIN:local.blb.lara}:{$HTTPS_PORT:443} {
	bind {$CADDY_BIND_ADDRESS:127.0.0.1}
	{$TLS_DIRECTIVE}

	import security_headers

	log {
		output file {$CADDY_LOG_DIR:.caddy/logs}/access.log
		format console
	}

	# Compress responses (HTML/JS/CSS/JSON). Caddy skips already-compressed
	# types and websockets. Biggest benefit for large pages and network access.
	encode zstd gzip

	# The Vite routes resolve only while the local development server is running.
	# The server sends reload updates only when VITE_HOT_RELOAD is enabled.
	import {$CADDY_VITE_SNIPPET:scripts/caddy-snippets/vite-disabled.caddy}

	# Laravel — FrankenPHP serves PHP and static files directly (no intermediate proxy)
	handle {
		root * public
		php_server
	}
}

{$CADDY_SCHEME:https}://{$BACKEND_DOMAIN:local.api.blb.lara}:{$HTTPS_PORT:443} {
	bind {$CADDY_BIND_ADDRESS:127.0.0.1}
	{$TLS_DIRECTIVE}

	import security_headers

	log {
		output file {$CADDY_LOG_DIR:.caddy/logs}/access.log
		format console
	}

	encode zstd gzip

	handle {
		root * public
		php_server
	}
}
