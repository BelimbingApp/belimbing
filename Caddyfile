# FrankenPHP Caddyfile — read by FrankenPHP's embedded Caddy (via Octane).
# {$VAR:default} placeholders are resolved by Caddy from environment variables at startup.
# Vite and Reverb remain reverse_proxy because they are separate Node/PHP processes.
#
# Octane passes --caddyfile=Caddyfile so this file is used instead of the
# default stub. The frankenphp worker block and admin endpoint mirror what
# the stub provides; the site blocks add TLS, Vite, and Reverb proxying.
{
	frankenphp {
		worker {
			file {$APP_PUBLIC_PATH}/frankenphp-worker.php
			{$CADDY_SERVER_WORKER_DIRECTIVE}
			{$CADDY_SERVER_WATCH_DIRECTIVES}
		}
	}

	admin {$CADDY_SERVER_ADMIN_HOST:localhost}:{$CADDY_SERVER_ADMIN_PORT:2019}
}

{$APP_DOMAIN:local.blb.lara} {
	{$TLS_DIRECTIVE:tls internal}

	log {
		output file {$CADDY_LOG_DIR:.caddy/logs}/access.log
		format console
	}

	# Reverb WebSocket (Laravel Echo — separate Reverb process)
	@reverb_ws {
		path /app/*
		expression `header({'Connection':'*Upgrade*','Upgrade':'websocket'}) || header({':protocol':'websocket'})`
	}
	handle @reverb_ws {
		reverse_proxy 127.0.0.1:{$REVERB_SERVER_PORT:8080}
	}

	# Vite HMR WebSocket (separate Vite process)
	@vite_ws {
		path /
		expression `header({'Connection':'*Upgrade*','Upgrade':'websocket'}) || header({':protocol':'websocket'})`
	}
	handle @vite_ws {
		reverse_proxy {$VITE_HOST:127.0.0.1}:{$VITE_PORT:5173}
	}

	# Vite dev assets (separate Vite process)
	@vite_dev path /@vite/* /@fs/* /node_modules/* /resources/*
	handle @vite_dev {
		reverse_proxy {$VITE_HOST:127.0.0.1}:{$VITE_PORT:5173}
	}

	# Laravel — FrankenPHP serves PHP and static files directly (no intermediate proxy)
	handle {
		root * public
		php_server
	}
}

{$BACKEND_DOMAIN:local.api.blb.lara} {
	{$TLS_DIRECTIVE:tls internal}

	log {
		output file {$CADDY_LOG_DIR:.caddy/logs}/access.log
		format console
	}

	handle {
		root * public
		php_server
	}
}
