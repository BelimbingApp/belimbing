# Application name. Shown in page titles, auth screens, and used for Redis/cache/session key prefixes when sharing infra. Change to your product name.
APP_NAME=Belimbing
# local — Development on your machine
# staging — Pre-production testing
# production — Live application
# testing — Automated tests (often set in phpunit.xml)
APP_ENV=local
APP_KEY=
# Detailed error pages with stack traces and config. Fine for local dev (this
# template ships local defaults); it MUST be false in production or it leaks
# internals. `php artisan blb:security:check` fails a production deploy when it
# is left true.
APP_DEBUG=true
APP_SCHEME=https
# Derived from APP_SCHEME and FRONTEND_DOMAIN during setup. Rarely needs manual override.
APP_URL=

# FrankenPHP / Caddy: domains for frontend and API.
# Add to /etc/hosts (and Windows hosts on WSL2) so the browser can resolve them.
FRONTEND_DOMAIN=local.blb.lara
BACKEND_DOMAIN=local.api.blb.lara

# Ingress mode for native runs:
# - shared = recommended default; system Caddy owns :80/:443 and proxies to BLB's app-local FrankenPHP listener
# - tunnel = public through Cloudflare Tunnel or another tunnel; BLB binds a local origin port
# - proxy = public through an existing IIS/nginx/Caddy/Apache reverse proxy; BLB binds a local origin port
# - standalone = BLB/FrankenPHP intentionally owns the LAN/public HTTPS listener
# - private = current machine or LAN-only access with no public ingress assumption
# - direct = legacy single-instance fallback; set standalone for intentional public binding
BLB_INGRESS_MODE=shared
# Optional stable instance name for Windows Scheduled Tasks (for example Prod,
# Stage, Demo). If unset, setup derives one from APP_ENV.
# BLB_INSTANCE_NAME=Local

# Reverse proxies whose X-Forwarded-* headers Laravel should trust for the real
# client IP and scheme. Comma-separated IPs/CIDRs. Leave unset to trust only the
# loopback + private ranges (correct when Caddy/FrankenPHP and any cloudflared
# tunnel share the host). Set to a distinct L7 proxy's address if one fronts the
# app; use '*' ONLY when that proxy strips inbound forwarded headers — trusting
# every client lets attackers spoof their IP and bypass login throttling.
# TRUSTED_PROXIES=

# Git is a required BLB dependency. Setup writes the resolved executable here so
# long-running services can run git even when their PATH differs from the setup shell.
# BLB_GIT_EXECUTABLE=/usr/bin/git
# Native Windows scheduled tasks run under SYSTEM, not your interactive profile.
# Setup pins tool paths here so production services do not depend on that
# account's HOME or PATH.
# BLB_FRANKENPHP_HOME=C:\Users\you\.frankenphp
# BLB_BUN_EXECUTABLE=C:\Users\you\.bun\bin\bun.exe

# HTTP 103 Early Hints (Link headers) for web GET/HEAD when PHP exposes headers_send() (FrankenPHP). Disabled on unsupported SAPIs.
# EARLY_HINTS_ENABLED=true

# Internal app/Vite ports (optional). If unset, start-app auto-assigns free ports.
# Set only when you need a fixed override; side-by-side local instances work without manual port changes.
# For shared ingress, pin APP_PORT so the generated system Caddy site config has a stable upstream target.
# APP_PORT=8000
# Optional direct-mode bind host. Shared ingress always forces loopback binding.
# APP_BIND_HOST=0.0.0.0
# Optional Caddy bind override. Tunnel/proxy modes should use 127.0.0.1;
# standalone direct mode may intentionally use 0.0.0.0 or a LAN address.
# CADDY_BIND_ADDRESS=127.0.0.1
# Optional staging/production origin port. Setup pins this when an external
# ingress or supervised Windows runtime needs a stable origin.
# HTTPS_PORT=8643
# Optional staging/production Caddy admin port for graceful worker reloads.
# CADDY_SERVER_ADMIN_PORT=2643
# Optional public health check for supervised Windows staging/production.
# Set this when the selected ingress mode has a public URL. The health task and
# deploy script assert the configured status/body boundary; this is useful for
# Cloudflare Access login/edge responses as well as direct app responses.
# BLB_PUBLIC_HEALTH_URL=https://blb.example.com
# BLB_PUBLIC_HEALTH_STATUS_PATTERN=^(200|302|401|403)$
# BLB_PUBLIC_HEALTH_BODY_PATTERN=
# VITE_PORT=5173

# TLS/SSL Certificate Mode for Caddy
# Controls how Caddy handles HTTPS certificates:
#
# - "internal" = Self-signed certificates generated by Caddy
#   Use for: Local dev, staging, or production behind another proxy
#   Requires: One-time SSL trust setup (automated on first run)
#
# - "email@example.com" = Let's Encrypt automatic certificates
#   Use for: Public-facing production with real domain
#   Requires: Valid domain pointing to your server, ports 80/443 open
#
# - Custom cert path in Caddyfile (set TLS_MODE=off or any non-email value)
#   Use for: Existing SSL certificates
#   Requires: Manual Caddyfile modification
#
# Local and testing environments always use "internal" regardless of this setting.
# TLS_MODE=internal

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Octane worker count. Default: 4. Both Artisan and native Windows launchers honor it.
# OCTANE_WORKERS=4
# Worker recycle limit per Octane worker. Default: 500.
# OCTANE_MAX_REQUESTS=500

# Bcrypt cost factor for password hashing (higher = slower, more secure; 12 is a good default)
BCRYPT_ROUNDS=12

# Logging: stack uses channels defined in config/logging.php
LOG_CHANNEL=stack
# Stack driver: single (one file), daily, stderr, etc.
LOG_STACK=single
# Deprecation notices: null to ignore, or a channel name
LOG_DEPRECATIONS_CHANNEL=null
# Log level: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=belimbing_local
DB_USERNAME=belimbing_app
# Use a dedicated application role; avoid reusing the PostgreSQL superuser unless you explicitly opt in during setup.
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Encrypt session payloads at rest. Recommended (true) unless a driver reason
# prevents it.
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Send the session cookie only over HTTPS. Leave unset for plain-http local dev;
# set true in any TLS deployment (blb:security:check warns/fails otherwise).
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Optional Lara prompt extension file (append-only, relative to project root).
# Core Lara prompt remains framework-managed in app/Modules/Core/AI/Resources/lara/system_prompt.md.
# AI_LARA_PROMPT_EXTENSION_PATH=storage/app/ai/lara_extension.md

# The agent bash tool runs arbitrary shell commands with the app's OS
# privileges. It is OFF by default in production (on in local/dev). Enable it
# only deliberately, ideally with the shell backend confined to a
# least-privileged OS user or sandbox, since a prompt injection could otherwise
# reach it as remote code execution.
# AI_BASH_TOOL_ENABLED=false

# ── SonarCloud ───────────────────────────────────────────────────────────
# Organization analysis token (Execute Analysis on belimbingapp). Used locally
# for API/review tooling and by scripts/ci/setup-sonar.php to bootstrap module
# CI secrets on GitHub. Generate at: https://sonarcloud.io/account/security
# SONAR_TOKEN=
